SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
WORMHOLE_RPC_URL=
# Robinhood Chain RPC — set to move IndexTrader off its stub and actually
# submit swaps to The Index's Uniswap v4 pools. Public RPC (rate-limited):
# https://rpc.mainnet.chain.robinhood.com — see docs.robinhood.com/chain
ROBINHOOD_RPC_URL=
X402_FACILITATOR_URL=
AGENT_MAX_TRADE_USD=1000
AGENT_MAX_DAILY_USD=5000
# Master kill-switch for autonomous execution — the background loop only acts
# on its own enter_index/exit_index decisions when this is "true" AND a signer
# is configured below. Defaults off.
AGENT_LIVE_TRADING=false
# Private key for the agent's own signing wallet — only used when
# AGENT_LIVE_TRADING=true. Generate one locally, fund it directly, and set
# this as a real environment variable on the host that runs the agent. Never
# commit this file with a real key in it, never paste a real key into a chat
# or ticket.
AGENT_SIGNER_PRIVATE_KEY=
# Cross-chain routing fee, in basis points on trade notional, settled via x402
# from the trade's own wallet (payer) when meridian_bridge_execute runs.
BRIDGE_FEE_BPS=8
# How often the background agent loop re-evaluates the strategy and logs a new
# "thought" (ms) — sets the cadence of the live monitor (GET /api/agent-thoughts).
AGENT_THINK_INTERVAL_MS=20000

# --- x402 signal/data paywall (receiving side) ---
# Wallet Meridian's paid tools get paid into. Left blank, gated tools still
# 402 correctly but the payTo address in the challenge is "unconfigured".
MERIDIAN_TREASURY_ADDRESS=
# Per-call prices in USD for the gated tools. Placeholders — tune with usage data.
PRICE_MARKET_DATA_USD=0.01
PRICE_SUGGEST_ROUTE_USD=0.05
PRICE_MARKET_UNIVERSE_USD=0.02

# Meridian MCP server (the layer an OpenHermit agent connects to)
MERIDIAN_MCP_HOST=127.0.0.1
MERIDIAN_MCP_PORT=8787
# Shared bearer for operator-only MCP tools (e.g. meridian_submit_research) and
# /api/ops. SET THIS IN PRODUCTION. Left blank the gate falls back to loopback
# only, so a public deploy that forgets it refuses those calls rather than
# accepting anonymous writes into the research pipeline the strategy reads.
MERIDIAN_MCP_TOKEN=
# URL the gateway uses to reach this server; only needed if it differs from host:port above
# (e.g. behind a reverse proxy or a different public hostname)
MERIDIAN_PUBLIC_MCP_URL=

# --- RWA research fleet provisioning (npm run provision-fleet) ---
# Without GATEWAY_ADMIN_TOKEN set, provisioning runs in dry-run mode (logs the plan only)
OPENHERMIT_GATEWAY_URL=http://127.0.0.1:4000
GATEWAY_ADMIN_TOKEN=
# Cheap model tier for the 12 research agents. Extraction-style research doesn't
# need frontier reasoning; keep the trading agent itself on a stronger model, set separately.
RWA_FLEET_MODEL_PROVIDER=anthropic
RWA_FLEET_MODEL_ID=claude-haiku-4-5

# --- Earn surfaces (advise-then-approve carry + scout-to-earn) ---
# Slippage floor (bps) on user-signed syrupUSDG carry swaps; near-par stable
# pair, so keep this tight. Per-transaction USD cap on prepared carry swaps.
EARN_CARRY_SLIPPAGE_BPS=50
EARN_CARRY_MAX_USD=25000
# What one validated novel scout finding accrues, and the caps that bound the
# worst case. Settlement (POST /api/admin/settle-bounties) pays balances above
# the minimum in USDG from the house wallet.
SCOUT_BOUNTY_USD=0.10
SCOUT_MAX_PER_WALLET_PER_DAY=3
SCOUT_MAX_DAILY_TOTAL_USD=5
SCOUT_MIN_PAYOUT_USD=0.50
# $INDEX yield entries: 6% slippage floor matches the house path's measured
# impact on this thin pool; funding leg (USDG->ETH bridge) gets a tight 1%.
# Per-transaction cap stays low because impact grows fast with size.
EARN_INDEX_SLIPPAGE_BPS=600
EARN_FUND_SLIPPAGE_BPS=100
EARN_INDEX_MAX_USD=1000
EARN_GAS_RESERVE_ETH=0.0003


# Auto-trading vaults (custody) — PREVIEW, off by default. Set a strong random
# 32+ char CUSTODY_SESSION_MASTER to enable: it derives each user's scoped
# session key (never stored). Keep it secret and backed up — losing it loses the
# ability to drive existing vaults (funds stay safe; users still own their Safe).
CUSTODY_SESSION_MASTER=
CUSTODY_MAX_PER_TRADE_USD=100

# =============================================================================
# SECURITY — set every one of these before exposing this service publicly.
# =============================================================================
# HMAC key for SIWE session bearers and sign-in nonces. UNSET IS THE DANGEROUS
# DEFAULT AT SCALE: the process falls back to a random per-boot secret, so every
# redeploy signs all users out, and with more than one replica a session minted
# on one box fails to verify on another. Generate once, then keep it stable:
#   openssl rand -hex 32
MERIDIAN_SESSION_SECRET=
# Dedicated bearer for FUND-MOVING MCP tools (index_execute, index_yield_execute,
# bridge_execute). Deliberately separate from MERIDIAN_MCP_TOKEN and placed in NO
# gateway registration, so an agent holding the shared token still cannot move
# funds. Blank = loopback only (fails closed, never open).
MERIDIAN_EXECUTE_TOKEN=

# --- House-wallet circuit breakers (defaults shown) ---------------------------
# Hard ceilings on autonomous wallet activity per 24h. These are the backstop if
# strategy logic misbehaves; lower them rather than raise them.
MERIDIAN_MAX_DAILY_WALLET_OPS=150
MERIDIAN_MAX_DAILY_NOTIONAL_USD=25000
# Cap on a single LP-guard recovery deployment. Above this the guard holds and
# defers to manual review instead of redeploying capital on its own.
MERIDIAN_MAX_RECOVERY_USD=2000

# --- Rate limiting (defaults shown) ------------------------------------------
# NOTE: these buckets are per process. With multiple replicas the effective
# ceiling is this value times the replica count, until they move to a shared store.
GLOBAL_RATE_PER_MIN=1800
AUTH_RATE_PER_MIN=30
CHAT_RATE_BURST=5
CHAT_RATE_REFILL_MS=3000
CHAT_MAX_CONCURRENT=40
CHAT_ACQUIRE_TIMEOUT_MS=15000

# --- X / Twitter (Merd's autonomous posting) ---------------------------------
# Real credentials. X_LIVE must be exactly "true" to post; anything else drafts
# only. Treat these like wallet keys: they can speak as the brand.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_LIVE=false
X_MAX_TWEET_CHARS=500

# --- Storage / durability ----------------------------------------------------
# Postgres mirror of the durable JSONL files. Unset, state lives only on the
# container disk and does not survive a redeploy.
DATABASE_URL=
MERIDIAN_DATA_DIR=
MERIDIAN_BACKUP_INTERVAL_MS=300000
MERIDIAN_POSITION_STATE_PATH=
MERIDIAN_UNIVERSE_PATH=

# --- Agent models ------------------------------------------------------------
MERIDIAN_FLEET_MODEL_PROVIDER=openrouter
MERIDIAN_FLEET_MODEL_ID=anthropic/claude-haiku-4.5
MERIDIAN_FLEET_OWNER_USER_ID=
MERIDIAN_USER_MODEL_PROVIDER=openrouter
MERIDIAN_USER_MODEL_ID=anthropic/claude-haiku-4.5
RWA_FLEET_WEB_PROVIDER=exa

# --- Strategy tuning (defaults shown) ----------------------------------------
AGENT_MIN_SPREAD_PCT=2
AGENT_SPREAD_PERSISTENCE_MINUTES=30
AGENT_MOMENTUM_LOOKBACK_MINUTES=240
AGENT_ROTATION_COOLDOWN_HOURS=24
AGENT_ROTATION_COST_MULTIPLE=3
MERIDIAN_AUTO_REBALANCE=
MERIDIAN_REBALANCE_COOLDOWN_HOURS=8
MERIDIAN_REBALANCE_MIN_GAIN_USD=2
MERIDIAN_REBALANCE_MAX_PAYBACK_DAYS=2
MERIDIAN_COLLECT_THRESHOLD_USD=3
LP_QUALIFY_MIN_DEPTH_USD=2000
LP_QUALIFY_TTL_MS=1800000
EARN_SWAP_DEADLINE_SEC=900
MERIDIAN_PRICE_TTL_MS=180000
MERIDIAN_INDEX_YIELD_TTL_MS=120000
MERIDIAN_LIVE_PRICES=
MERIDIAN_WALLET_ADDRESS=
MERIDIAN_OPEN_DEPLOY_HOUR_UTC=14
MERIDIAN_OPEN_DEPLOY_PLAN=

# --- Research loggers (set to "true" to run; sample intervals in ms) ----------
MERIDIAN_RUN_BASIS_LOGGER=
MERIDIAN_RUN_LIGHTER_LOGGER=
MERIDIAN_RUN_YIELD_LOGGER=
BASIS_SAMPLE_MS=300000
BASIS_LOG_MAX_LINES=20000
LIGHTER_SAMPLE_MS=1800000
LIGHTER_API_BASE=https://api.rh.lighter.xyz
YIELD_SAMPLE_MS=3600000

# --- x402 prices for the remaining gated tools (USD) -------------------------
PRICE_PERP_FEED_USD=0.05
PRICE_BASIS_FEED_USD=0.1
PRICE_CARRY_QUOTE_USD=0.02
PRICE_LP_SCORE_USD=0.05
