SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
WORMHOLE_RPC_URL=
# Robinhood Chain RPC. READ endpoint (primary). Point this at a dedicated
# provider (Alchemy is Robinhood's recommended one) to escape the public RPC's
# rate limits. Public, rate-limited: https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_RPC_URL=
# Optional explicit READ fallback, tried after the primary and before the public
# endpoint (which is always the final fallback). Reads fail over automatically.
ROBINHOOD_RPC_FALLBACK_URL=
# WRITE endpoint: transaction submission goes here, straight to the sequencer for
# the fewest hops to inclusion (the tx-speed edge). Leave blank to use the public
# sequencer-backed endpoint even when reads run on a dedicated provider. Only set
# this for a private/dedicated sequencer endpoint.
ROBINHOOD_WRITE_RPC_URL=
X402_FACILITATOR_URL=
AGENT_MAX_TRADE_USD=1000
AGENT_MAX_DAILY_USD=5000
# Master kill-switch for autonomous execution — the background loop only acts
# on its own enter_index/exit_index decisions when this is "true" AND a signer
# is configured below. Defaults off.
AGENT_LIVE_TRADING=false
# Private key for the agent's own signing wallet — only used when
# AGENT_LIVE_TRADING=true. Generate one locally, fund it directly, and set
# this as a real environment variable on the host that runs the agent. Never
# commit this file with a real key in it, never paste a real key into a chat
# or ticket.
AGENT_SIGNER_PRIVATE_KEY=
# Cross-chain routing fee, in basis points on trade notional, settled via x402
# from the trade's own wallet (payer) when meridian_bridge_execute runs.
BRIDGE_FEE_BPS=8
# How often the background agent loop re-evaluates the strategy and logs a new
# "thought" (ms) — sets the cadence of the live monitor (GET /api/agent-thoughts).
AGENT_THINK_INTERVAL_MS=20000

# --- x402 signal/data paywall (receiving side) ---
# Wallet Meridian's paid tools get paid into. Set the real address in Railway
# (see AGENTS.md — live config lives there, not in this template). Left blank,
# gated tools still 402 correctly but the payTo in the challenge is "unconfigured".
MERIDIAN_TREASURY_ADDRESS=
# Per-call prices in USD for the gated tools. Placeholders — tune with usage data.
PRICE_MARKET_DATA_USD=0.01
PRICE_SUGGEST_ROUTE_USD=0.05
PRICE_MARKET_UNIVERSE_USD=0.02

# Meridian MCP server (the layer an OpenHermit agent connects to)
MERIDIAN_MCP_HOST=127.0.0.1
MERIDIAN_MCP_PORT=8787
# Set to require `Authorization: Bearer <token>` on /mcp; leave blank for open local dev
MERIDIAN_MCP_TOKEN=
# URL the gateway uses to reach this server; only needed if it differs from host:port above
# (e.g. behind a reverse proxy or a different public hostname)
MERIDIAN_PUBLIC_MCP_URL=

# --- RWA research fleet provisioning (npm run provision-fleet) ---
# Without GATEWAY_ADMIN_TOKEN set, provisioning runs in dry-run mode (logs the plan only)
OPENHERMIT_GATEWAY_URL=http://127.0.0.1:4000
GATEWAY_ADMIN_TOKEN=
# Cheap model tier for the 12 research agents. Extraction-style research doesn't
# need frontier reasoning; keep the trading agent itself on a stronger model, set separately.
RWA_FLEET_MODEL_PROVIDER=anthropic
RWA_FLEET_MODEL_ID=claude-haiku-4-5

# --- Earn surfaces (advise-then-approve carry + scout-to-earn) ---
# Slippage floor (bps) on user-signed syrupUSDG carry swaps; near-par stable
# pair, so keep this tight. Per-transaction USD cap on prepared carry swaps.
EARN_CARRY_SLIPPAGE_BPS=50
EARN_CARRY_MAX_USD=25000
# What one validated novel scout finding accrues, and the caps that bound the
# worst case. Settlement (POST /api/admin/settle-bounties) pays balances above
# the minimum in USDG from the house wallet.
SCOUT_BOUNTY_USD=0.10
SCOUT_MAX_PER_WALLET_PER_DAY=3
SCOUT_MAX_DAILY_TOTAL_USD=5
SCOUT_MIN_PAYOUT_USD=0.50
# $INDEX yield entries: 6% slippage floor matches the house path's measured
# impact on this thin pool; funding leg (USDG->ETH bridge) gets a tight 1%.
# Per-transaction cap stays low because impact grows fast with size.
EARN_INDEX_SLIPPAGE_BPS=600
EARN_FUND_SLIPPAGE_BPS=100
EARN_INDEX_MAX_USD=1000
EARN_GAS_RESERVE_ETH=0.0003


# Auto-trading vaults (custody) — PREVIEW, off by default. Set a strong random
# 32+ char CUSTODY_SESSION_MASTER to enable: it derives each user's scoped
# session key (never stored). Keep it secret and backed up — losing it loses the
# ability to drive existing vaults (funds stay safe; users still own their Safe).
CUSTODY_SESSION_MASTER=
CUSTODY_MAX_PER_TRADE_USD=100
