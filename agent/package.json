{
  "name": "@meridian/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Meridian RWA-DEX domain exposed as an MCP server for OpenHermit agents",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "provision-fleet": "tsx src/research/orchestration.ts",
    "provision-reserved": "tsx --env-file=.env src/deploy/userAgents.ts",
    "test": "tsx --test test/**/*.test.ts",
    "backtest": "tsx src/backtest/simulate.ts",
    "backtest:legacy-momentum": "tsx src/backtest/simulate.legacy-momentum.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@openhermit/sdk": "^0.7.0",
    "express": "^4.21.2",
    "viem": "^2.55.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
